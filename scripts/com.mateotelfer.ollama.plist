<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key><string>com.mateotelfer.ollama</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/ollama</string>
        <string>serve</string>
    </array>
    <key>RunAtLoad</key><true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key><false/>
    </dict>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/mateotelfer/Claude Code - Working Folder/career-ai-explorer/scripts/logs/ollama.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/mateotelfer/Claude Code - Working Folder/career-ai-explorer/scripts/logs/ollama.err.log</string>
    <key>ThrottleInterval</key><integer>5</integer>
</dict>
</plist>
